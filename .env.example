# --- Gemini AI (OBLIGATORIO) ---
GEMINI_API_KEY="MY_GEMINI_API_KEY"
# Modelo opcional (por defecto: gemini-2.5-flash)
# GEMINI_MODEL="gemini-2.5-flash"

# --- OpenRouter (OPCIONAL — fallback si Gemini falla) ---
OPENROUTER_API_KEY=""
OPENROUTER_MODEL="google/gemini-2.0-flash-001"

# --- Supabase (OBLIGATORIO para persistencia real) ---
SUPABASE_URL="https://leswzmfcdeincvuvnyze.supabase.co"
SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Imxlc3d6bWZjZGVpbmN2dXZueXplIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODEyMTA5NTEsImV4cCI6MjA5Njc4Njk1MX0.-Nz06CSipOzOhP6hZ5kyRP9jUmSYoepGurenIZ0AQL8"
# Recomendado en producción: los webhooks/schedulers usan esta clave (bypassa RLS).
# Dashboard → Project Settings → API → service_role. NUNCA la expongas al frontend.
SUPABASE_SERVICE_ROLE_KEY=""

# --- Mercado Pago (para links de pago REALES generados por el bot) ---
# https://www.mercadopago.com.ar/developers/panel → Credenciales → Access Token
MP_ACCESS_TOKEN=""

# --- Sync de catálogo/stock desde tu tienda (opcional, elegí UNA) ---
TIENDANUBE_STORE_ID=""     # ID numérico de la tienda
TIENDANUBE_TOKEN=""        # Access token de la app de TiendaNube
SHOPIFY_STORE=""           # ej: mitienda.myshopify.com
SHOPIFY_TOKEN=""           # Admin API access token
WOO_URL=""                 # ej: https://mitienda.com
WOO_KEY=""                 # consumer key (WooCommerce → Ajustes → API)
WOO_SECRET=""              # consumer secret

# --- WhatsApp / Meta API (OPCIONAL — para recibir mensajes reales) ---
# Docs: https://developers.facebook.com/docs/whatsapp/cloud-api/get-started
WHATSAPP_TOKEN=""
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_APP_SECRET=""
WEBHOOK_VERIFY_TOKEN="respondo-verify-secret-cambiame"

# URL PÚBLICA de la app — necesaria para los webhooks de Meta.
# En local usá un túnel (ver CONEXION-WHATSAPP.md), ej: https://xxxx.trycloudflare.com
APP_URL="MY_APP_URL"

# --- Facebook Messenger + Instagram Direct (OPCIONAL) ---
FB_PAGE_TOKEN=""
IG_TOKEN=""   # si queda vacío usa FB_PAGE_TOKEN

# --- Email (OPCIONAL) ---
EMAIL_USER=""       # dirección "from" que ve el cliente
RESEND_API_KEY=""   # envío saliente vía Resend (https://resend.com)

# --- Server ---
PORT=3000
NODE_ENV=development
LOG_LEVEL=info
